<body>
<bookmark id="bm_id671782332499010" branch="hid/.uno:ClearRecentFileList" localize="false"/>
<bookmark branch="index" id="bm_id111782333384126">
<bookmark_value>recent documents;clear list</bookmark_value>
</bookmark>
<section id="clearlist">
    <h1 id="hd_id691782332499010"><variable id="h1"><link href="text/shared/01/ClearRecentFileList.xhp">Clear Recent Document List</link></variable></h1>
    <description id="par_id581782332499010">Clears the recent document list.</description>
</section>
<section id="howtoget">
    <embed href="text/shared/00/00000004.xhp#from_menu_bar"/>
    <paragraph role="paragraph" id="par_id231782332646899">Choose <menuitem>File - Recent Documents - Clear List</menuitem>.</paragraph>
    <embed href="text/shared/00/00000004.xhp#from_tabUI"/>
    <paragraph role="paragraph" id="par_id391782332829261">On the <menuitem>File</menuitem> tab, do a long click on <menuitem>Open</menuitem> and choose <menuitem>Clear List</menuitem>.</paragraph>
    <paragraph role="paragraph" id="par_id901782332935130">On the <menuitem>File</menuitem> menu of the <menuitem>File</menuitem> tab, choose <menuitem>Recent Documents - Clear List</menuitem>.</paragraph>
    <paragraph role="paragraph" id="par_id611782333158704">On the top left toolbar of the tabbed interface, do a long click on <menuitem>Open</menuitem> and choose <menuitem>Clear List</menuitem>.</paragraph>
    <embed href="text/shared/00/00000004.xhp#from_startcenter"/>
    <paragraph role="paragraph" id="par_id651782334064945">On the top right drop-down menu, choose <menuitem>Clear Recent Documents</menuitem>.</paragraph>
</section>
</body>
</helpdocument>
