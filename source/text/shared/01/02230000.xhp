<body>
<section id="track_changes">
<bookmark branch="hid/.uno:ChangesMenu" id="bm_id8352305" localize="false"/>

<h1 id="hd_id3152952"><variable id="track_changes_h1"><link href="text/shared/01/02230000.xhp">Track Changes</link></variable></h1>
<description id="par_id3145759"><ahelp hid=".">Lists the commands that are available for tracking changes in your file.</ahelp></description>
</section>

<section id="howtoget">
<embed href="text/shared/00/edit_menu.xhp#changes"/>
</section>
<embed href="text/shared/01/02230100.xhp#record_changes"/>
<embed href="text/shared/01/02230200.xhp#showchanges"/>

<h3 id="hd_id711773240204742">Previous</h3>
<paragraph role="paragraph" id="par_id261773252152722">Jumps to and selects the previous change in the document, if any.</paragraph>
<h3 id="hd_id951773240208733">Next</h3>
<paragraph role="paragraph" id="par_id791773252128690">Jumps to and selects the next change in the document, if any.</paragraph>
<bookmark branch="hid/.uno:AcceptTrackedChange" id="bm_id0122200903133817" localize="false"/>
<h3 id="hd_id111773240211958">Accept</h3>
<paragraph role="paragraph" id="par_id81773252547112">Accepts the tracked change.</paragraph>

<bookmark branch="hid/.uno:AcceptTrackedChangeToNext" id="bm_id191773252628079" localize="false"/>
<h3 id="hd_id851773240216758">Accept and Move to Next</h3>
<paragraph role="paragraph" id="par_id221773252574376">Accepts the change and jump to next tracked change.</paragraph>

<bookmark branch="hid/.uno:AcceptAllTrackedChanges" id="bm_id581773252199104" localize="false"/>
<h3 id="hd_id751773240221757">Accept All</h3>
<paragraph role="paragraph" id="par_id291773252479282">Accepts all tracked changes.</paragraph>

<bookmark branch="hid/.uno:RejectTrackedChange" id="bm_id0122200903140685" localize="false"/>
<h3 id="hd_id131773240225461">Reject</h3>
<paragraph role="paragraph" id="par_id341773252493169">Rejects the tracked change.</paragraph>

<bookmark branch="hid/.uno:RejectTrackedChangeToNext" id="bm_id971773253212169" localize="false"/>
<h3 id="hd_id751773240229973">Reject and Move to Next</h3>
<paragraph role="paragraph" id="par_id751773252519113">Rejects the change and jump to next tracked change.</paragraph>

<bookmark branch="hid/.uno:RejectAllTrackedChanges" id="bm_id61773252419971" localize="false"/>
<h3 id="hd_id211773240234437">Reject All</h3>
<paragraph role="paragraph" id="par_id311773252446770">Rejects all tracked changes</paragraph>

<bookmark branch="hid/.uno:ReinstateTrackedChange" id="bm_id981773253250344" localize="false"/>
<h3 id="hd_id271773240238861">Reject but Track</h3>
<paragraph role="paragraph" id="par_id381773253363087">Reinstates the original state, with the rejected change preserved in the document.</paragraph>

<bookmark branch="hid/.uno:ReinstateTrackedChangeToNext" id="bm_id321773253399325" localize="false"/>
<h3 id="hd_id561773240243301">Reject but Track and Move to Next</h3>
<paragraph role="paragraph" id="par_id161773251875440">Reject tracked change but keep rejected change tracked and move to next change.</paragraph>

<bookmark branch="hid/.uno:ReinstateAllTrackedChanges" id="bm_id381773251703900" localize="false"/>
<h3 id="hd_id931773240247629">Reject but Track All</h3>
<paragraph role="paragraph" id="par_id491773251828401">Reject all tracked changes but keep rejected changes tracked.</paragraph>
