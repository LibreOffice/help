<body>
<bookmark branch="index" id="bm_id691780510071267">
    <bookmark_value>sections;in presentations</bookmark_value>
    <bookmark_value>presentation;sections</bookmark_value>
</bookmark>
<section id="section_presentation">
    <h1 id="hd_id811780509059760"><variable id="h1"><link href="text/simpress/guide/sections.xhp">Presentation sections</link></variable></h1>
    <description id="par_id341780509059760">Sections help you organize your slides into logical groups, making it easier to navigate, manage, and collaborate on large presentations.</description>
</section>
<section id="howtoget">
    <embed href="text/shared/00/00000004.xhp#from_context"/>
    <paragraph role="paragraph" id="par_id271780509276429">Click on a slide in the slide pane and choose <menuitem>Add section</menuitem>.</paragraph>
</section>
<bookmark branch="hid/.uno:AddSlideSection" id="bm_id601780510832728" localize="false"/>
<h2 id="hd_id741780509675055">To add a section</h2>
<list type="ordered">
    <listitem>
        <paragraph id="par_id931780509398151"  role="listitem">Open the presentation.</paragraph>
    </listitem>
    <listitem>
        <paragraph id="par_id151780509855323"  role="listitem">In the left pane (Slide panel view), right-click between two slides where you want to add a section.</paragraph>
    </listitem>
    <listitem>
        <paragraph id="par_id201780509411296"  role="listitem">Select <menuitem>Add Section</menuitem>.</paragraph>
    </listitem>
</list>
<paragraph role="paragraph" id="par_id411780509683337">A new section named "Untitled Section" is added. Proceed to optionally rename the section.</paragraph>
<bookmark branch="hid/.uno:RenameSlideSection" id="bm_id531780510800482" localize="false"/>
<h2 id="hd_id181780509668411">To rename a section</h2>
<list type="ordered">
    <listitem>
        <paragraph id="par_id321780509646062"  role="listitem">Right-click the section name in the Slide pane.</paragraph>
    </listitem>
    <listitem>
        <paragraph id="par_id441780509652268"  role="listitem">Select <menuitem>Rename Section</menuitem> and type the new name in the name box. </paragraph>
    </listitem>
</list>
<bookmark id="bm_id521780509059760" branch="hid/.uno:RemoveSlideSection" localize="false"/>
<h2 id="hd_id551780509725865">To remove a section</h2>
<list type="ordered">
    <listitem>
        <paragraph id="par_id811780509810520"  role="listitem">Right-click the section name in the Slide pane.</paragraph>
    </listitem>
    <listitem>
        <paragraph id="par_id401780509815849"  role="listitem">Choose <menuitem>Remove section</menuitem> (this only removes the section, not the slides).</paragraph>
    </listitem>
</list>
