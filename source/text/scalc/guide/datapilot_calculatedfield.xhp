        <title id="tit">Pivot Table Calculated Field</title>
        <filename>/text/scalc/guide/datapilot_calculatedfield.xhp</filename>
    </topic>
</meta>
<body>
<bookmark id="bm_id771779151018515" branch="hid/modules/scalc/ui/pivotcalcfielddialog/PivotCalcField" localize="false"/>
<bookmark id="bm_id731779151018515" branch="hid/modules/scalc/ui/pivotcalcfielddialog/@@nowidget@@" localize="false"/>
<bookmark branch="index" id="bm_id651779216111106">
<bookmark_value>pivot table;calculated field</bookmark_value>
<bookmark_value>calculated field;pivot table</bookmark_value>
</bookmark>
<section id="calculatedfield">
    <h1 id="hd_id391779151018515"><variable id="h1"><link href="text/scalc/guide/datapilot_calculatedfield.xhp">Pivot Table Calculated Field</link></variable></h1>
    <description id="par_id791779151018515">Create a new pivot table data column using a custom formula.</description>
</section>
<paragraph role="paragraph" id="par_id741779215670448">A Calculated Field lets you add a new data column with a custom formula, and unlike manually entered columns, it becomes a built-in part of the Pivot Table. This ensures that sorting, filtering, and other Pivot Table functions work seamlessly.</paragraph>
<section id="howtoget">
    <paragraph role="paragraph" id="par_id581779217252143">Place cursor inside an existing pivot table, then</paragraph>
    <embed href="text/shared/00/00000004.xhp#from_menu_bar"/>
    <paragraph role="paragraph" id="par_id591779217314215">Choose <menuitem>Data > Pivot Table > Calculated Field</menuitem>.</paragraph>
    <embed href="text/shared/00/00000004.xhp#from_context"/>
    <paragraph role="paragraph" id="par_id71779217350764">Choose <menuitem>Calculated Field</menuitem>.</paragraph>
    <embed href="text/shared/00/00000004.xhp#from_tabUI"/>
    <paragraph role="paragraph" id="par_id471779218276448">On the <menuitem>Data</menuitem> menu of the <menuitem>Data</menuitem> tab, choose <menuitem>Pivot Calculated Field</menuitem></paragraph>
</section>
<bookmark branch="hid/modules/scalc/ui/pivotcalcfielddialog/calcfieldscb" id="bm_id241779151385184" localize="false"/>
<h2 id="hd_id381779152416650">Name</h2>
<paragraph role="paragraph" id="par_id861779215700848">The name of the calculated field. This name will appear as an additional entry in the Fields list.</paragraph>
<bookmark branch="hid/modules/scalc/ui/pivotcalcfielddialog/calcentry" id="bm_id81779151412045" localize="false"/>
<h2 id="hd_id571779152543327">Formula</h2>
<paragraph role="paragraph" id="par_id731779215705911">The formula of the calculated field. The formula syntax is the same as any other formula cell in Calc.</paragraph>
<bookmark branch="hid/modules/scalc/ui/pivotcalcfielddialog/listbox-fields" id="bm_id1001779151416558" localize="false"/>
<h2 id="hd_id411779152548485">Fields</h2>
<paragraph role="paragraph" id="par_id961779215710863">Display the list of fields and calculated fields. All fields of this list can be used in calculated fields formulas.</paragraph>
<bookmark branch="hid/modules/scalc/ui/pivotcalcfielddialog/insertbtn" id="bm_id921779151420675" localize="false"/>
<h2 id="hd_id621779152553173">Insert Field</h2>
<paragraph role="paragraph" id="par_id281779215719060">Click to add the calculated field to the Field list.</paragraph>
<bookmark branch="hid/modules/scalc/ui/pivotcalcfielddialog/addbtn" id="bm_id851779151424837" localize="false"/>
<h2 id="hd_id541779152557453">Add</h2>
<paragraph role="paragraph" id="par_id831779196715514">Adds the calculated field to the pivot table fields.</paragraph>
<bookmark branch="hid/modules/scalc/ui/pivotcalcfielddialog/modbtn" id="bm_id141779151428517" localize="false"/>
<h2 id="hd_id331779152562869">Modify</h2>
<paragraph role="paragraph" id="par_id761779196720167">Modifies the calculated field formula and update the Fields list.</paragraph>
<bookmark branch="hid/modules/scalc/ui/pivotcalcfielddialog/deletebtn" id="bm_id481779151433049" localize="false"/>
<h2 id="hd_id621779152567265">Delete</h2>
<paragraph role="paragraph" id="par_id81779196646476">Deletes the calculated field.</paragraph>
