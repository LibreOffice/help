<meta>
    <topic id="text/scalc/06/mathmlfunc.xhp" indexer="exclude" status="PUBLISH">
        <title id="tit">MathML Equations</title>
        <filename>/text/scalc/06/mathmlfunc.xhp</filename>
    </topic>
</meta>
<body>
<section id="imcot">
<m:math xmlns:m="http://www.w3.org/1998/Math/MathML" display="block">
<m:semantics>
  <m:mrow>
   <m:mi>cot</m:mi>
   <m:mrow>
    <m:mrow>
     <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
     <m:mrow>
      <m:mrow>
       <m:mi>a</m:mi>
       <m:mo stretchy="false">+</m:mo>
       <m:mi mathvariant="italic">bi</m:mi>
      </m:mrow>
     </m:mrow>
     <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
    </m:mrow>
    <m:mo stretchy="false">=</m:mo>
    <m:mfrac>
     <m:mrow>
      <m:mi>sin</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>a</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mi>i</m:mi>
      </m:mrow>
      <m:mi>sinh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>b</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
     <m:mrow>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>b</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mi>cos</m:mi>
      </m:mrow>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>a</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
    </m:mfrac>
   </m:mrow>
  </m:mrow>
  <m:annotation encoding="StarMath 5.0">cot ( a + bi ) ={ sin(2a) - i sinh(2b)} over {cosh(2b) - cos(2a)}</m:annotation>
 </m:semantics>
</m:math>

</section>
</body>
