<body>
<section id="imcsc">
<m:math xmlns:m="http://www.w3.org/1998/Math/MathML" display="block">
 <m:semantics>
  <m:mrow>
   <m:mi>csc</m:mi>
   <m:mrow>
    <m:mrow>
     <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
     <m:mrow>
      <m:mrow>
       <m:mi>a</m:mi>
       <m:mo stretchy="false">+</m:mo>
       <m:mi mathvariant="italic">bi</m:mi>
      </m:mrow>
     </m:mrow>
     <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
    </m:mrow>
    <m:mo stretchy="false">=</m:mo>
    <m:mfrac>
     <m:mrow>
      <m:mn>2</m:mn>
      <m:mi>sin</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>a</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mi>b</m:mi>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mn>2</m:mn>
      </m:mrow>
      <m:mi>i</m:mi>
      <m:mspace width="0.5em"/>
      <m:mi>cos</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>a</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
      <m:mi>sinh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>b</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
     <m:mrow>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>b</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mi>cos</m:mi>
      </m:mrow>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>a</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
    </m:mfrac>
   </m:mrow>
  </m:mrow>
  <m:annotation encoding="StarMath 5.0">func csc(a+bi)={2sin(a)cosh(b)-2i`cos(a)sinh(b)} over {cosh(2b)-cos(2a)} </m:annotation>
 </m:semantics>
</m:math>
</section>
<section id="imcsch">
<m:math xmlns:m="http://www.w3.org/1998/Math/MathML" display="block">
 <m:semantics>
  <m:mrow>
   <m:mi>csch</m:mi>
   <m:mrow>
    <m:mrow>
     <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
     <m:mrow>
      <m:mrow>
       <m:mi>a</m:mi>
       <m:mo stretchy="false">+</m:mo>
       <m:mi mathvariant="italic">bi</m:mi>
      </m:mrow>
     </m:mrow>
     <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
    </m:mrow>
    <m:mo stretchy="false">=</m:mo>
    <m:mfrac>
     <m:mrow>
      <m:mn>2</m:mn>
      <m:mi>sinh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>a</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
      <m:mi>cos</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mi>b</m:mi>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mn>2</m:mn>
      </m:mrow>
      <m:mi>i</m:mi>
      <m:mspace width="0.5em"/>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>a</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
      <m:mi>sin</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>b</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
     <m:mrow>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>a</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mi>cos</m:mi>
      </m:mrow>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>b</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
    </m:mfrac>
   </m:mrow>
  </m:mrow>
  <m:annotation encoding="StarMath 5.0">func csch(a+bi)={2sinh(a)cos(b)-2i`cosh(a)sin(b)} over {cosh(2a)-cos(2b)}</m:annotation>
 </m:semantics>
</m:math>
</section>
<section id="imsech">
<m:math xmlns:m="http://www.w3.org/1998/Math/MathML" display="block">
 <m:semantics>
  <m:mrow>
   <m:mi>sech</m:mi>
   <m:mrow>
    <m:mrow>
     <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
     <m:mrow>
      <m:mrow>
       <m:mi>a</m:mi>
       <m:mo stretchy="false">+</m:mo>
       <m:mi mathvariant="italic">bi</m:mi>
      </m:mrow>
     </m:mrow>
