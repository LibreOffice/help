      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>a</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
      <m:mi>cos</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mi>b</m:mi>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mn>2</m:mn>
      </m:mrow>
      <m:mi>i</m:mi>
      <m:mspace width="0.5em"/>
      <m:mi>sinh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>a</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
      <m:mi>sin</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>b</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
     <m:mrow>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>a</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">+</m:mo>
       <m:mi>cos</m:mi>
      </m:mrow>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>b</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
    </m:mfrac>
   </m:mrow>
  </m:mrow>
  <m:annotation encoding="StarMath 5.0">func sech(a+bi)={2cosh(a)cos(b)-2i`sinh(a)sin(b)} over {cosh(2a)+cos(2b)}</m:annotation>
 </m:semantics>
</m:math>
</section>
<section id="imsec">
<m:math xmlns:m="http://www.w3.org/1998/Math/MathML" display="block">
 <m:semantics>
  <m:mrow>
   <m:mi>sec</m:mi>
   <m:mrow>
    <m:mrow>
     <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
     <m:mrow>
      <m:mrow>
       <m:mi>a</m:mi>
       <m:mo stretchy="false">+</m:mo>
       <m:mi mathvariant="italic">bi</m:mi>
      </m:mrow>
     </m:mrow>
     <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
    </m:mrow>
    <m:mo stretchy="false">=</m:mo>
    <m:mfrac>
     <m:mrow>
      <m:mn>2</m:mn>
      <m:mi>cos</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>a</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mi>b</m:mi>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">+</m:mo>
       <m:mn>2</m:mn>
      </m:mrow>
      <m:mi>i</m:mi>
      <m:mspace width="0.5em"/>
      <m:mi>sin</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>a</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
      <m:mi>sinh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mi>b</m:mi>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
     <m:mrow>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>b</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">+</m:mo>
       <m:mi>cos</m:mi>
      </m:mrow>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>a</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
    </m:mfrac>
   </m:mrow>
  </m:mrow>
  <m:annotation encoding="StarMath 5.0">func sec(a+bi)={2cos(a)cosh(b)+2i`sin(a)sinh(b)} over {cosh(2b)+cos(2a)}</m:annotation>
 </m:semantics>
</m:math>
</section>
<section id="imtan">
<m:math xmlns:m="http://www.w3.org/1998/Math/MathML" display="block">
 <m:semantics>
  <m:mrow>
   <m:mi>tan</m:mi>
   <m:mrow>
    <m:mrow>
     <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
     <m:mrow>
      <m:mrow>
       <m:mi>a</m:mi>
       <m:mo stretchy="false">+</m:mo>
       <m:mi mathvariant="italic">bi</m:mi>
      </m:mrow>
     </m:mrow>
     <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
    </m:mrow>
    <m:mo stretchy="false">=</m:mo>
    <m:mfrac>
     <m:mrow>
      <m:mi>sin</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>a</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">+</m:mo>
       <m:mi>i</m:mi>
      </m:mrow>
      <m:mspace width="0.5em"/>
      <m:mi>sinh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>b</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
     <m:mrow>
      <m:mi>cos</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>a</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">+</m:mo>
       <m:mi>cosh</m:mi>
      </m:mrow>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>b</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
    </m:mfrac>
   </m:mrow>
  </m:mrow>
  <m:annotation encoding="StarMath 5.0">tan(a+bi)={sin(2a)+i`sinh(2b)} over {cos(2a)+cosh(2b)} </m:annotation>
 </m:semantics>
</m:math>
</section>
<section id="imcot">
<m:math xmlns:m="http://www.w3.org/1998/Math/MathML" display="block">
<m:semantics>
  <m:mrow>
   <m:mi>cot</m:mi>
   <m:mrow>
    <m:mrow>
     <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
     <m:mrow>
      <m:mrow>
       <m:mi>a</m:mi>
       <m:mo stretchy="false">+</m:mo>
       <m:mi mathvariant="italic">bi</m:mi>
      </m:mrow>
     </m:mrow>
     <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
    </m:mrow>
    <m:mo stretchy="false">=</m:mo>
    <m:mfrac>
     <m:mrow>
      <m:mi>sin</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>a</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mi>i</m:mi>
      </m:mrow>
      <m:mi>sinh</m:mi>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>b</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
     <m:mrow>
      <m:mi>cosh</m:mi>
      <m:mrow>
       <m:mrow>
        <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
        <m:mrow>
         <m:mrow>
          <m:mn>2</m:mn>
          <m:mi>b</m:mi>
         </m:mrow>
        </m:mrow>
        <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
       </m:mrow>
       <m:mo stretchy="false">−</m:mo>
       <m:mi>cos</m:mi>
      </m:mrow>
      <m:mrow>
       <m:mo fence="true" form="prefix" stretchy="false">(</m:mo>
       <m:mrow>
        <m:mrow>
         <m:mn>2</m:mn>
         <m:mi>a</m:mi>
        </m:mrow>
       </m:mrow>
       <m:mo fence="true" form="postfix" stretchy="false">)</m:mo>
      </m:mrow>
     </m:mrow>
    </m:mfrac>
   </m:mrow>
  </m:mrow>
  <m:annotation encoding="StarMath 5.0">cot ( a + bi ) ={ sin(2a) - i sinh(2b)} over {cosh(2b) - cos(2a)}</m:annotation>
 </m:semantics>
</m:math>

</section>
</body>
